<a href="{{ path('reference-car:public.car-brands.show', {'brandName': item.url}) }}"
   class="card rounded-4 border-0 mb-3 p-2">
    <div class="card-image-wrap overflow-hidden rounded-4 border border-light" style="height: 100px;">
        <div class="card-brand-logo" title="{{ item.name }}">
            <img src="/assets/reference-car/image/Brand/{{ item.id }}.png" alt="">
        </div>
    </div>
    <div class="card-body px-3 py-3">
        <h2 class="card-title mb-2 h6 w-100 text-center">
            <div class="d-inline-block text-decoration-none text-dark text-truncate"
                 style="max-width: 180px;">{{ item.name }}</div>
        </h2>
    </div>
</a>
