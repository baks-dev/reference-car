{% trans_default_domain('reference-car.public') %}

<section class="container grid grid-template-column-6 gap-3 mt-5">
    {% for item in query %}
        {{ include(_self|replace({ "content.html.twig": "card.html.twig" })) }}
    {% endfor %}
</section>

<style>
    .grid {
        display: grid;
    }

    .grid-template-column-6 {
        grid-template-columns: repeat(6, 1fr);
    }

    .card {
        transition: box-shadow 0.3s ease-in-out;
        box-shadow: none;
    }

    .card:hover {
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
        /* Альтернативные варианты теней: */
        /* box-shadow: 0 4px 8px rgba(0,0,0,0.2); */
        /* box-shadow: 0 5px 15px rgba(0,0,0,0.3); */
    }

    .card .card-brand-logo {
        width: 100%;
        height: 100%;
    }

    .card img {
        height: 100%;
        width: 100%;
        object-fit: contain;
    }
</style>