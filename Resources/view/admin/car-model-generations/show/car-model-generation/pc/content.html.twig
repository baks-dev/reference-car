{% trans_default_domain('reference-car.admin') %}
<main class="main d-print-none ">

    <section class="container px-4 mb-5">

        <div class="mt-3 d-flex justify-content-between">
            {{ include(_self|replace({ "content.html.twig": "_breadcrumb.html.twig" })) }}
        </div>

        <h1 class="h3 text-uppercase fw-bolder">
            {{ 'page.model.show'|trans }} {{ carGeneration.name }}
        </h1>

        <div class="d-flex gap-5 mt-3">
            <div class="w-50 d-flex flex-column">
                <div class="d-flex flex-column gap-3">

                    <div class="d-flex justify-content-between p-2 rounded-4 bg-light">

                        <div class="w-50"> Марка</div>

                        <div class="w-50 d-flex gap-3 align-items-center">
                            <a
                               href="{{ path('reference-car:admin.car-brands.show', {'id': carGeneration.brandId}) }}"
                               class="text-muted"
                               title="{{ carGeneration.brandName }}"> {{ carGeneration.brandName }}
                            </a>
                        </div>

                    </div>

                    <div class="d-flex justify-content-between p-2 rounded-4 bg-light">

                        <div class="w-50">Модель</div>

                        <div class="w-50 d-flex gap-3 align-items-center">
                            <a
                               href="{{ path('reference-car:admin.car-model.show', {'id': carGeneration.id}) }}"
                               class="text-muted"
                               title="{{ carGeneration.name }}"> {{ carGeneration.name }}
                            </a>
                        </div>

                    </div>

                </div>
            </div>
        </div>

        <hr class="mt-5 rounded-circle border-0" style="height: 20px; box-shadow: 0 -20px 20px -6px #000;">

        <div class="d-flex justify-content-between">
            <h5 class="text-uppercase fw-bolder py-3">Комплектации поколения {{ carGeneration.name }}</h5>
        </div>

        <div class="d-flex justify-content-between gap-3">
            <div class="tab-content w-100">
                <div class="tab-pane fade show active">
                    <div class="border rounded-4 p-3 small">
                        <table class="table table-striped table-borderless">

                            <thead>
                                <tr>

                                    <th scope="col">Id</th>

                                    <th scope="col">Наименование</th>

                                </tr>
                            </thead>

                            <tbody>
                                {% for item in carPetrols %}
                                    <tr class="vertical-middle">

                                        <th scope="row">{{ item.id }}</th>

                                        <th>
                                            <a href="{{ path('reference-car:admin.car-models-petrols.show', {'id': item.id}) }}">
                                                {{ item.name }}
                                            </a>
                                        </th>

                                    </tr>
                                {% endfor %}
                            </tbody>

                        </table>
                    </div>
                </div>
            </div>
        </div>

    </section>
</main>