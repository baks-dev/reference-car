{% trans_default_domain('reference-car.admin') %}
<main class="main d-print-none ">
    <section class="container px-4 mb-5">

        <div class="mt-3 d-flex justify-content-between">
            {{ include(_self|replace({ "content.html.twig": "_breadcrumb.html.twig" })) }}
        </div>

        <h1 class="h3 text-uppercase fw-bolder">
            {{ 'page.petrol.show'|trans }}
            {{ carModelPetrol.brandName }}
            {{ carModelPetrol.modelName }}
            {{ carModelPetrol.name }}
            {{ carModelPetrol.hpValue }} HP
        </h1>

        <div class="d-flex gap-5 mt-3">
            <div class="w-50 d-flex flex-column">
                <div class="d-flex flex-column gap-3">

                    <div class="d-flex justify-content-between p-2 rounded-4 bg-light">
                        <div class="w-50">Марка</div>
                        <div class="w-50 d-flex gap-3 align-items-center">
                            <a href="{{ path('reference-car:admin.car-brands.show', {'id': carModelPetrol.Id}) }}"
                               class="text-muted"
                               title="{{ carModelPetrol.brandName }}"> {{ carModelPetrol.brandName }}
                            </a>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between p-2 rounded-4 bg-light">
                        <div class="w-50">Модель</div>
                        <div class="w-50 d-flex gap-3 align-items-center">
                            <a href="{{ path('reference-car:admin.car-model.show', {'id': carModelPetrol.modelId}) }}"
                               class="text-muted"
                               title="{{ carModelPetrol.modelName }}"> {{ carModelPetrol.modelName }}
                            </a>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between p-2 rounded-4 bg-light">
                        <div class="w-50">Поколение</div>
                        <div class="w-50 d-flex gap-3 align-items-center">
                            <span class="text-muted">
                                {{ carModelPetrol.generationName }}
                            </span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between p-2 rounded-4 bg-light">
                        <div class="w-50">Комплектация</div>
                        <div class="w-50 d-flex gap-3 align-items-center">
                        <span href="" class="text-muted"
                              title="{{ carModelPetrol.name }}"> {{ carModelPetrol.name }}
                        </span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between p-2 rounded-4 bg-light">
                        <div class="w-50">Выпуск</div>
                        <div class="w-50 d-flex gap-1 align-items-center">

                            <span class="text-muted">{{ carModelPetrol.years }}</span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between p-2 rounded-4 bg-light">
                        <div class="w-50">Мощность двигателя</div>
                        <div class="w-50 d-flex gap-3 align-items-center">
                        <span href="" class="text-muted">
                            {{ carModelPetrol.HPValue }} hp |
                            {{ carModelPetrol.KWValue }} kw |
                            {{ carModelPetrol.PSValue }} ps
                        </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <hr class="mt-5 rounded-circle border-0" style="height: 20px; box-shadow: 0 -20px 20px -6px #000;">

        <div class="d-flex justify-content-between">
            <h5 class="text-uppercase fw-bolder py-3">
                Шины комплектации {{ carModelPetrol.name }}</h5>
        </div>

        <div class="d-flex justify-content-between gap-3">
            <div class="tab-content w-100">
                <div class="tab-pane fade show active">
                    <div class="border rounded-4 p-3 small">
                        <table class="table table-striped table-borderless">
                            <thead>
                                <tr>
                                    <th scope="col">Id</th>
                                    <th scope="col">Диаметр</th>
                                    <th scope="col">Профиль</th>
                                    <th scope="col">Ширина</th>
                                    <th scope="col">Обод(Rim)</th>
                                    <th scope="col">Диапазон смещения(Offset Range)</th>
                                    <th scope="col">Давление(Bar)</th>
                                    <th scope="col">Вес(Tire Weight)</th>
                                    <th scope="col">Возврат(Backspacing)</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in carModelWheels %}
                                    <tr class="vertical-middle">
                                        <th scope="row">{{ item.id }}</th>
                                        <th>{{ item.diameter }}</th>
                                        <th>{{ item.profile }}</th>
                                        <th>{{ item.width }}</th>
                                        <th>{{ item.rim }}</th>
                                        <th>{{ item.offsetRange }}</th>
                                        <th>{{ item.bar }}</th>
                                        <th>{{ item.tireWeight }}</th>
                                        <th>{{ item.backspacing }}</th>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </section>
</main>