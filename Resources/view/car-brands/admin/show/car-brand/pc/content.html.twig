{% trans_default_domain('admin.reference.car') %}
<main class="main d-print-none ">

    <section class="container px-4 mb-5">

        <div class="mt-3 d-flex justify-content-between">
            {{ include(_self|replace({ "content.html.twig": "_breadcrumb.html.twig" })) }}
        </div>

        {#        <div class="d-flex justify-content-between align-items-center mb-3 gap-3"> #}

        {#            <div class="w-100"> #}
        {#                <h1 class="h4 text-uppercase fw-bolder mb-0"> #}
        {#                    {{ 'admin.page.brand.show'|trans }} #}
        {#                </h1> #}
        {#            </div> #}
        {#        </div> #}

        <h1 class="h3 text-uppercase fw-bolder">
            {{ 'admin.page.brand.show'|trans }} {{ carBrand.name }}
        </h1>

        <div class="d-flex gap-5 mt-3">
            <div class="w-auto">
                <div class="icon rounded-5 border lazy bg-contain shadow-none entered loaded"
                     style="
                             width: 350px;
                             height: 350px;
                             background-image: url('/assets/reference-car/image/Brand/{{ carBrand.id }}.png');
                             title:'{{ carBrand.name }}';"
                     data-ll-status="loaded"></div>
            </div>
            <div class="w-100 d-flex flex-column">
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex justify-content-between p-2 rounded-4 bg-light">
                        <div class="w-50"> Марка
                        </div>
                        <div class="w-50 d-flex gap-3 align-items-center">
                            <span href="" class="text-muted"
                                  title="{{ carBrand.name }}"> {{ carBrand.name }}
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            <div id="product_payment" class="w-100 d-flex flex-column align-items-start">
                <div class="mb-2 bg-light rounded-4 w-100 gap-3 px-5 py-4">
                </div>
            </div>
        </div>
        <hr class="mt-5 rounded-circle border-0" style="height: 20px; box-shadow: 0 -20px 20px -6px #000;">
        <div class="d-flex justify-content-between">
            <h5 class="text-uppercase fw-bolder py-3">
                Модели бренда {{ carBrand.name }}</h5>
        </div>

        <div class="d-flex justify-content-between gap-3">
            <div class="tab-content w-100">
                <div class="tab-pane fade show active">
                    <div class="border rounded-4 p-3 small">
                        <table class="table table-striped table-borderless">
                            <thead>
                            <tr>
                                <th scope="col">Id</th>
                                <th scope="col">Наименование</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for item in carModels.data %}
                                <tr class="vertical-middle">
                                    <th scope="row">{{ item.id }}</th>
                                    <th>
                                        <a href="{{ path('reference-car:car-models.admin.show', {'id': item.id}) }}">
                                            {{ item.name }}
                                        </a>
                                    </th>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>


    </section>

</main>